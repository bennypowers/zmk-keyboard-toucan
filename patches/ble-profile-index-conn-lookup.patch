@@ -262,6 +262,34 @@ int zmk_ble_profile_index(const bt_addr_le_t *addr) {
     return -ENODEV;
 }
 
+int zmk_ble_profile_index_for_conn(const struct bt_conn *conn) {
+    const bt_addr_le_t *addr = bt_conn_get_dst(conn);
+    int idx = zmk_ble_profile_index(addr);
+    if (idx >= 0) {
+        return idx;
+    }
+
+    /* After host suspend/resume, bt_conn_get_dst may return an address form
+     * (RPA vs identity) that doesn't match the stored profile. Reverse-lookup:
+     * find which profile's stored address resolves to this connection. */
+    for (int i = 0; i < ZMK_BLE_PROFILE_COUNT; i++) {
+        if (!bt_addr_le_cmp(&profiles[i].peer, BT_ADDR_LE_ANY)) {
+            continue;
+        }
+        struct bt_conn *profile_conn =
+            bt_conn_lookup_addr_le(BT_ID_DEFAULT, &profiles[i].peer);
+        if (profile_conn != NULL) {
+            bool match = (profile_conn == conn);
+            bt_conn_unref(profile_conn);
+            if (match) {
+                return i;
+            }
+        }
+    }
+
+    return -ENODEV;
+}
+
